# Copiar a .env y completar. NUNCA subir el .env real a git.

# Dominio base. Ejemplos: researchflow.duckdns.org o midominio.com
# Caddy publicara: n8n.DOMAIN y evo.DOMAIN
DOMAIN=researchflow.duckdns.org

# Zona horaria
TZ=America/La_Paz

# Password unico para Postgres (n8n, researchflow y evolution usan este servidor)
POSTGRES_PASSWORD=cambiar-por-password-largo

# Clave de cifrado de credenciales de n8n. Generar con: openssl rand -hex 24
# GUARDARLA: si se pierde, se pierden las credenciales guardadas en n8n.
N8N_ENCRYPTION_KEY=cambiar-por-clave-generada

# API key global de Evolution API (inventar una larga). Se usa tambien en los
# nodos HTTP de n8n que llaman a Evolution (header apikey).
EVOLUTION_API_KEY=cambiar-por-api-key-larga
