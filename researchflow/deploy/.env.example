# Copiar a .env y completar. NUNCA subir el .env real a git.

# Dominio base. Ejemplos: researchflow.duckdns.org o midominio.com
# Caddy publicara: n8n.DOMAIN y evo.DOMAIN
DOMAIN=researchflow.duckdns.org

# Zona horaria
TZ=America/La_Paz

# Password unico para Postgres (n8n, researchflow y evolution usan este servidor)
POSTGRES_PASSWORD=cambiar-por-password-largo

# Clave de cifrado de credenciales de n8n. Generar con: openssl rand -hex 24
# GUARDARLA: si se pierde, se pierden las credenciales guardadas en n8n.
N8N_ENCRYPTION_KEY=cambiar-por-clave-generada

# API key global de Evolution API (inventar una larga). Se usa tambien en los
# nodos HTTP de n8n que llaman a Evolution (header apikey).
EVOLUTION_API_KEY=cambiar-por-api-key-larga

# ---- Configuracion de los workflows (inyectada a n8n via $env) ----
# Con esto NO hay que editar los nodos uno por uno: se leen desde aqui.

# API key de Gemini (https://aistudio.google.com > Get API key)
GEMINI_API_KEY=cambiar-por-api-key-gemini

# ID del Google Spreadsheet con una hoja llamada 'datasets'
# (es el codigo largo en la URL: docs.google.com/spreadsheets/d/<ESTE_ID>/edit)
GOOGLE_SHEET_ID=cambiar-por-id-del-spreadsheet

# Datos del propietario (destinatario de correos/WhatsApp y remitente de solicitudes)
OWNER_NAME=Tu Nombre
OWNER_EMAIL=tucorreo@gmail.com
# Numero de WhatsApp en formato internacional sin +, ej. 59170000000
OWNER_WHATSAPP=59170000000
# (Opcional) Base del webhook para la auto-llamada del workflow "Ideas por WhatsApp"
# al workflow de investigacion. Por defecto http://localhost:5678 (misma instancia).
# En produccion detras de Caddy puedes usar la URL publica:
# RF_WEBHOOK_BASE=https://n8n.researchflow.duckdns.org
RF_WEBHOOK_BASE=http://localhost:5678
